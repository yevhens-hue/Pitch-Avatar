                "region": {
                  "startLine": 18,
                  "endLine": 30,
                  "snippet": {
                    "text": "export async function POST(req: Request) {\n  try {\n    const body = await req.json();\n    const { type, title, avatarName, role, userId } = body;\n\n    console.log('[Sara CreateProject] called:', { type, userId, hasServiceKey: !!SERVICE_ROLE_KEY });\n\n    if (!type) {\n      return NextResponse.json({ error: 'type is required' }, { status: 400 });\n    }\n    if (!userId) {\n      return NextResponse.json({ error: 'userId is required' }, { status: 400 });\n    }"
                  }
                }
              },
              "message": {
                "text": "Add session authentication before processing body fields"
              }
            },
