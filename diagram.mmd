graph TD
    %% Утолщение связей
    linkStyle default stroke-width:3px,stroke:black;

    Start([Пользователь создает Enrollment])

    Start --> Event{Событие}
    
    Event -- Квота свободна --> SuccessTrigger[Enrollment создан<br>Статус: Pending]
    Event -- Квота заполнена --> ErrorTrigger[Ошибка: Quota Exceeded<br>Показ Overage Modal]
    
    ErrorTrigger --> Action1{Действие?}
    Action1 -- Клик на Upgrade --> RedirectBilling[Переход в Billing]
    Action1 -- Отмена / Закрыть --> Hidden[Остановка создания]
    
    RedirectBilling --> Start
    
    SuccessTrigger --> Deduct[Списание 1 места из квоты<br>Виджет обновляется]
    Deduct --> Timer[Запуск таймера Expiration<br>По умолчанию 14 дней]
    
    Timer --> ListenerAction{Действие слушателя?}
    
    ListenerAction -- Открыл до истечения --> View[Презентация открыта<br>Место остается занятым]
    ListenerAction -- Таймер истек --> ExpireStatus[Статус меняется на Expired]
    
    ExpireStatus --> Return[Возврат 1 места в квоту<br>Счетчик откатывается]
    
    Return --> LateAction{Слушатель кликает<br>на старую ссылку?}
    LateAction -- Да --> Blocked[Экран-заглушка: Ссылка просрочена]
    Blocked --> Safe[Квота НЕ списывается повторно]

    %% Светлая тема с более жирными контурами
    classDef start fill:#eff6ff,stroke:#2563eb,color:#1e3a8a,stroke-width:3px;
    classDef decision fill:#fffbeb,stroke:#d97706,color:#92400e,stroke-width:3px;
    classDef actionGreen fill:#ecfdf5,stroke:#059669,color:#065f46,stroke-width:3px;
    classDef actionRed fill:#fef2f2,stroke:#dc2626,color:#991b1b,stroke-width:3px;
    classDef actionBlue fill:#f8fafc,stroke:#475569,color:#0f172a,stroke-width:3px;
    
    class Start start;
    class Event,Action1,ListenerAction,LateAction decision;
    class SuccessTrigger,Deduct,Timer,View,Return,Safe actionGreen;
    class ErrorTrigger,ExpireStatus,Blocked actionRed;
    class RedirectBilling,Hidden actionBlue;
