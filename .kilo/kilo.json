{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "figma-dev-mode": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/sse"
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "environment": {
        "DEFAULT_MINIMUM_TOKENS": "{{DEFAULT_MINIMUM_TOKENS}}"
      }
    },
    "fireproof": {
      "type": "local",
      "command": [
        "node",
        "{{FIREPROOF_PATH}}/build/index.js"
      ]
    },
    "laravel-boost": {
      "type": "local",
      "command": [
        "php",
        "artisan",
        "boost:mcp"
      ]
    }
  }
}
